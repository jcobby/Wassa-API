PORT=4000
MONGO_URI=mongodb://localhost:27017/wpn
JWT_SECRET=change_me_to_a_long_random_string
FRONTEND_ORIGIN=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000
COOKIE_DOMAIN=
NODE_ENV=development

# Email (Zoho SMTP) — hosted/custom-domain accounts use smtppro.zoho.com
EMAIL_FROM="WPN <admin@wassaprosnetwork.org>"
SMTP_HOST=smtppro.zoho.com
SMTP_PORT=465
SMTP_USER=admin@wassaprosnetwork.org
# App-specific password from Zoho (Settings → Security → App Passwords)
SMTP_PASS=
# Dev only: route every outgoing email to this address so you don't mail real
# people while testing. Leave blank in production.
TEST_EMAIL_OVERRIDE=

# Paystack (payments) — TEST keys for dev, LIVE keys for prod
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Only used by `npm run seed:admin`
ADMIN_EMAIL=admin@wassaprofessionals.org
ADMIN_PASSWORD=change-me
ADMIN_FULL_NAME=WPN Administrator
