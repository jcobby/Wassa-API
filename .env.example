PORT=4000
MONGO_URI=mongodb://localhost:27017/wpn
JWT_SECRET=change_me_to_a_long_random_string
FRONTEND_ORIGIN=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000
COOKIE_DOMAIN=
